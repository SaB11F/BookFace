<Window x:Class="SocialnoOmrezje.Views.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Urejanje prijateljev"
        Height="500"
        Width="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Style="{StaticResource HeroFrameStyle}">
            <StackPanel>
                <TextBlock Text="FRIEND EDITOR"
                           Style="{StaticResource EyebrowStyle}"/>
                <TextBlock Text="Curate the people around your wall"
                           Margin="0,8,0,8"
                           Style="{StaticResource PanelTitleStyle}"/>
                <TextBlock Text="Add, rename or remove friends without leaving the current session."
                           Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource WindowFrameStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Tvoj krog"
                               Style="{StaticResource FieldLabelStyle}"/>

                    <ListBox x:Name="FriendsListBox"
                             Grid.Row="1"
                             Margin="0,12,0,0"
                             SelectionChanged="FriendsListBox_SelectionChanged"/>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource TintedFrameStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Friend name"
                               Style="{StaticResource FieldLabelStyle}"/>

                    <TextBox x:Name="FriendNameTextBox"
                             Grid.Row="1"
                             Margin="0,0,0,18"/>

                    <Button Grid.Row="2"
                            Margin="0,0,0,10"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddFriend_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE710;"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Dodaj"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="3"
                            Margin="0,0,0,10"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="UpdateFriend_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE70F;"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Uredi"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Row="4"
                                VerticalAlignment="Top">
                        <Button Margin="0,0,0,10"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="RemoveFriend_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE74D;"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Odstrani"/>
                            </StackPanel>
                        </Button>

                        <Border Margin="0,14,0,16"
                                Style="{StaticResource WindowFrameStyle}">
                            <TextBlock Text="Tip: click a friend on the left to load the name here before editing."
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </Border>

                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="Close_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE711;"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Zapri"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
