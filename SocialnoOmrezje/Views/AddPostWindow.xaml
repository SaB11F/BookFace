<Window x:Class="SocialnoOmrezje.Views.AddPostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj objavo"
        Height="470"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer>
        <StackPanel Margin="15">

            <TextBlock Text="Vsebina:"/>
            <TextBox x:Name="ContentTextBox"
                     Height="80"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Lokacija:"/>
            <TextBox x:Name="LocationTextBox"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Stevilo vseckov:"/>
            <TextBox x:Name="LikesTextBox"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Oznaceni prijatelji (loceni z vejico):"/>
            <TextBox x:Name="TaggedFriendsTextBox"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Slika:"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox x:Name="ImagePathTextBox"
                         Width="255"
                         IsReadOnly="True"/>
                <Button Margin="6,0,0,0"
                        Click="SelectImage_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" Margin="0,0,6,0"/>
                        <TextBlock Text="Izberi"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="6">
                <Image x:Name="PreviewImage"
                       Height="130"
                       Stretch="Uniform"
                       Cursor="Hand"
                       MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                       ToolTip="Klikni za izbiro slike"/>
            </Border>

            <Button x:Name="ConfirmButton"
                    Margin="0,12,0,0"
                    Width="120"
                    HorizontalAlignment="Right"
                    Click="Confirm_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" Margin="0,0,6,0"/>
                    <TextBlock Text="Potrdi"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Window>
