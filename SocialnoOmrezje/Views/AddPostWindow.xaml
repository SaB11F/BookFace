<Window x:Class="SocialnoOmrezje.Views.AddPostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj objavo"
        Height="640"
        Width="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Style="{StaticResource HeroFrameStyle}">
            <StackPanel>
                <TextBlock Text="POST COMPOSER"
                           Style="{StaticResource EyebrowStyle}"/>
                <TextBlock Text="Build a post that feels deliberate"
                           Margin="0,8,0,8"
                           Style="{StaticResource PanelTitleStyle}"/>
                <TextBlock Text="Mix text, place, people and a visual so each post reads like a proper card in the wall."
                           TextWrapping="Wrap"
                           Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource WindowFrameStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Vsebina" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="ContentTextBox"
                                 Height="110"
                                 Margin="0,0,0,16"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"/>

                        <TextBlock Text="Lokacija" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="LocationTextBox"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Stevilo vseckov" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="LikesTextBox"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Oznaceni prijatelji" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TaggedFriendsTextBox"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Pot do slike" Style="{StaticResource FieldLabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ImagePathTextBox"
                                     Grid.Column="0"
                                     Margin="0,0,10,0"
                                     IsReadOnly="True"/>

                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="SelectImage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE8B7;"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Izberi"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource TintedFrameStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="LIVE PREVIEW"
                                   Style="{StaticResource EyebrowStyle}"/>
                        <TextBlock Text="Click the image to swap visuals"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,16,0,16"
                            Background="{StaticResource PaperBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="24"
                            Padding="10">
                        <Grid>
                            <Image x:Name="PreviewImage"
                                   Stretch="UniformToFill"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                                   ToolTip="Klikni za izbiro slike"/>

                            <Border VerticalAlignment="Bottom"
                                    HorizontalAlignment="Left"
                                    Margin="10"
                                    Background="#CC1F2A30"
                                    CornerRadius="14"
                                    Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE114;"
                                               Foreground="{StaticResource PaperBrush}"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="Photo area"
                                               Foreground="{StaticResource PaperBrush}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Button x:Name="ConfirmButton"
                            Grid.Row="2"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Click="Confirm_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE73E;"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="ConfirmButtonText"
                                       Text="Potrdi"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
